    "/api/accounts/loginByPhone": {
      "post": {
        "summary": "手机号登录",
        "deprecated": false,
        "description": "通过手机号和可选代理登录 WhatsApp，返回配对码。\n\n参数说明：\n- phoneNumber: 手机号，支持多种格式，建议 E.164 格式（不带加号）\n- proxy: 可选，SOCKS5 代理地址\n- sessionId: 可选，会话ID\n- callbackUrl: 可选，登录成功回调地址",
        "tags": [
          "accounts"
        ],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "phoneNumber": {
                    "type": "string",
                    "description": "手机号，支持多种格式"
                  },
                  "proxy": {
                    "type": "string",
                    "description": "SOCKS5 代理地址，可选"
                  },
                  "sessionId": {
                    "type": "string",
                    "description": "会话ID，可选"
                  },
                  "callbackUrl": {
                    "type": "string",
                    "description": "登录成功回调地址，可选"
                  }
                },
                "required": ["phoneNumber"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "accountId": {
                      "type": "string"
                    },
                    "phoneNumber": {
                      "type": "string"
                    },
                    "pairingCode": {
                      "type": "string",
                      "description": "配对码"
                    },
                    "message": {
                      "type": "string"
                    },
                    "instructions": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "操作步骤"
                    }
                  }
                },
                "examples": {
                  "手机号登录成功": {
                    "value": {
                      "success": true,
                      "accountId": "1234567890",
                      "phoneNumber": "8613800138000",
                      "pairingCode": "123-456",
                      "message": "配对码已生成，请在您的 WhatsApp 应用中输入此代码",
                      "instructions": [
                        "1. 打开您手机上的 WhatsApp 应用",
                        "2. 进入设置 > 已连接的设备",
                        "3. 点击\"连接设备\"",
                        "4. 选择\"使用手机号码连接\"",
                        "5. 输入配对码: 123-456",
                        "6. 等待连接完成"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "security": [],
        "x-apifox-folder": "accounts",
        "x-apifox-status": "developing"
      }
    },

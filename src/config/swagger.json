    "/api/messages/link": {
      "post": {
        "summary": "发送链接消息（带按钮）",
        "deprecated": false,
        "description": "发送带按钮的链接消息，使用 malvin-btns 的 sendButtons 方法\n\n支持三种按钮类型：\n- cta_url: 点击跳转链接 (需要 url 字段)\n- cta_call: 点击拨打电话 (需要 phoneNumber 字段)\n- quick_reply: 快速回复按钮 (需要 id 字段)",
        "tags": [
          "message"
        ],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "accountId": {
                    "type": "string",
                    "description": "账号ID或手机号",
                    "example": "86xxxxx"
                  },
                  "to": {
                    "type": "string",
                    "description": "接收方手机号或JID",
                    "example": "86xxxx"
                  },
                  "title": {
                    "type": "string",
                    "description": "消息标题",
                    "example": "产品介绍"
                  },
                  "body": {
                    "type": "string",
                    "description": "消息正文",
                    "example": "我们最新的产品已经上线，欢迎查看详细信息和购买。"
                  },
                  "footer": {
                    "type": "string",
                    "description": "底部文本",
                    "example": "点击下方按钮访问产品页面"
                  },
                  "imageUrl": {
                    "type": "string",
                    "description": "图片URL",
                    "example": "https://www.baidu.com/img/PCtm_d9c8750bed0b3c7d089fa7d55720d6cf.png"
                  },
                  "buttons": {
                    "type": "array",
                    "description": "按钮列表，最多3个",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "description": "按钮唯一ID（quick_reply类型必填）"
                        },
                        "display_text": {
                          "type": "string",
                          "description": "按钮显示文字",
                          "example": "查看产品"
                        },
                        "name": {
                          "type": "string",
                          "enum": ["cta_url", "cta_call", "quick_reply"],
                          "description": "按钮类型：cta_url=链接, cta_call=电话, quick_reply=快速回复（默认）",
                          "example": "cta_url"
                        },
                        "url": {
                          "type": "string",
                          "description": "链接URL（cta_url类型必填）",
                          "example": "https://www.bilibili.com/"
                        },
                        "phoneNumber": {
                          "type": "string",
                          "description": "电话号码（cta_call类型必填）"
                        }
                      },
                      "required": ["display_text"]
                    }
                  }
                },
                "required": ["accountId", "to", "body", "buttons"]
              },
              "examples": {
                "URL链接按钮": {
                  "value": {
                    "accountId": "86xxxxx",
                    "to": "86xxxx",
                    "title": "产品介绍",
                    "body": "我们最新的产品已经上线，欢迎查看详细信息和购买。",
                    "footer": "点击下方按钮访问产品页面",
                    "imageUrl": "https://www.baidu.com/img/PCtm_d9c8750bed0b3c7d089fa7d55720d6cf.png",
                    "buttons": [
                      {
                        "name": "cta_url",
                        "display_text": "查看产品",
                        "url": "https://www.bilibili.com/"
                      }
                    ]
                  }
                },
                "多个快速回复按钮": {
                  "value": {
                    "accountId": "86xxxxx",
                    "to": "86xxxx",
                    "title": "🤖 客服菜单",
                    "body": "请选择你需要的服务：",
                    "footer": "点击按钮回复",
                    "buttons": [
                      { "id": "help", "display_text": "🆘 帮助" },
                      { "id": "contact", "display_text": "📞 联系客服" },
                      { "id": "website", "display_text": "🌐 访问官网" }
                    ]
                  }
                },
                "电话按钮": {
                  "value": {
                    "accountId": "86xxxxx",
                    "to": "86xxxx",
                    "title": "📞 联系我们",
                    "body": "如有紧急问题，请直接拨打：",
                    "buttons": [
                      {
                        "name": "cta_call",
                        "display_text": "立即拨打",
                        "phoneNumber": "+8613800138000"
                      }
                    ]
                  }
                },
                "混合按钮": {
                  "value": {
                    "accountId": "86xxxxx",
                    "to": "86xxxx",
                    "title": "🎉 活动邀请",
                    "body": "我们即将举办线上活动，请选择：",
                    "footer": "期待你的参与",
                    "imageUrl": "https://www.baidu.com/img/PCtm_d9c8750bed0b3c7d089fa7d55720d6cf.png",
                    "buttons": [
                      {
                        "name": "cta_url",
                        "display_text": "查看详情",
                        "url": "https://www.bilibili.com/"
                      },
                      {
                        "id": "join",
                        "display_text": "我要参加"
                      },
                      {
                        "name": "cta_call",
                        "display_text": "咨询电话",
                        "phoneNumber": "+8613800138000"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "number",
                      "description": "状态码"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "Success": {
                          "type": "boolean"
                        },
                        "ErrMsg": {
                          "type": "string"
                        },
                        "To": {
                          "type": "string"
                        },
                        "Status": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "成功响应": {
                    "value": {
                      "status": 200,
                      "data": {
                        "Success": true,
                        "ErrMsg": "",
                        "To": "86xxxx",
                        "Status": "sent"
                      }
                    }
                  },
                  "失败响应": {
                    "value": {
                      "status": 400,
                      "message": "Buttons must be an array"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "number"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "服务器错误",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "number"
                    },
                    "data": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [],
        "x-apifox-folder": "message",
        "x-apifox-status": "developing"
      }

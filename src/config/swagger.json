    "/api/messages/bulk": {
      "post": {
        "summary": "批量发送消息",
        "deprecated": false,
        "description": "批量发送多条消息，最多100条",
        "tags": [
          "message"
        ],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "accountId": {
                    "type": "string"
                  },
                  "messages": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "to": {
                          "type": "string"
                        },
                        "content": {
                          "type": "string"
                        },
                        "type": {
                          "type": "string",
                          "enum": ["text", "pic"]
                        },
                        "base64mediacontent": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "required": ["accountId", "messages"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
